# =============================================================================
# 文件名:   home/readline.nix
# 功能描述: Readline（命令行输入库）配置
# 说明:     从 ~/dotfiles/.inputrc 迁移至 Home Manager 管理。
#           配置 Bash/Zsh 等使用 Readline 的程序的输入行为。
# =============================================================================
{ config, pkgs, ... }:

{
  # ===========================================================================
  # Readline 配置
  # ===========================================================================
  programs.readline = {
    # --- 启用 Readline ---
    enable = true;

    # --- Readline 配置 ---
    extraConfig = ''
      # ================================================================
      # 历史搜索
      # 让 ↑/↓ 只匹配已输入的前缀
      # ================================================================
      "\e[A": history-search-backward   # ↑ 向上搜索历史
      "\e[B": history-search-forward    # ↓ 向下搜索历史

      # ================================================================
      # 补全设置
      # ================================================================
      set completion-ignore-case on     # 补全忽略大小写
      set show-all-if-ambiguous on      # 直接显示所有匹配项
    '';
  };
}
