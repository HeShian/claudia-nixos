# =============================================================================
# 文件名:   modules/_core/default.nix
# 功能描述: 核心系统模块聚合入口
# 说明:     导入所有核心系统子模块，包括引导、网络、Nix 设置、安全、系统包
# =============================================================================
{ config, pkgs, ... }:

{
  imports = [
    ./boot.nix              # 引导与内核
    ./network.nix           # 网络基础配置
    ./nix-settings.nix      # Nix 自身设置（镜像源、GC、环境变量）
    ./security.nix          # 用户与安全
    ./system-packages.nix   # 系统级软件包
    ./swap.nix              # 交换空间
  ];
}
