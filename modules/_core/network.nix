# =============================================================================
# 文件名:   modules/_core/network.nix
# 功能描述: 网络基础配置
# 说明:     配置主机名、网络管理工具等基础网络设置
# =============================================================================
{ config, pkgs, ... }:

{
  # --- 1. 主机名 ---
  networking.hostName = "westwood";

  # --- 2. 网络管理 ---
  # 使用 NetworkManager 管理网络连接（支持 GUI 配置）
  networking.networkmanager.enable = true;
}
