# =============================================================================
# 文件名:   modules/_core/swap.nix
# 功能描述: 交换空间配置
# 说明:     创建系统交换文件，用于休眠支持和内存压力时的缓冲。
#           当前系统内存 15GB，交换文件设为 8GB（足够日常使用和轻度休眠）。
# =============================================================================
{ ... }:

{
  # --- 交换文件（位于 /var/lib/swapfile，大小可调整） ---
  # 如需支持完整休眠，建议设置为内存大小的 1~1.5 倍
  # 如果完全不需要交换空间，可注释下面整个 swapDevices 配置
  swapDevices = [{
    device = "/var/lib/swapfile";
    size = 8192;  # 8GB 交换文件
  }];
}
