# =============================================================================
# 文件名:   modules/hardware/bluetooth.nix
# 功能描述: 蓝牙支持配置（BlueZ）
# 说明:     启用系统蓝牙服务、自动开机上电，并安装蓝牙管理工具
# =============================================================================
{ ... }:

{
  # --- 启用蓝牙支持 ---
  hardware.bluetooth = {
    enable = true;
    powerOnBoot = true;   # 启动时自动打开蓝牙控制器
  };

  # Blueman 未安装 — 蓝牙配对由 Noctalia Shell 内置模块处理
}
