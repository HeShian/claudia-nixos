# =============================================================================
# 文件名:   modules/network/ssh-client.nix
# 功能描述: 远程连接工具配置
# 说明:     安装远程桌面客户端和文件传输工具
# =============================================================================
{ config, pkgs, ... }:

{
  # --- 远程连接工具 ---
  environment.systemPackages = with pkgs; [
    remmina     # 远程桌面客户端（支持 RDP/VNC/SSH）
    localsend   # 局域网文件传输工具
  ];
}
